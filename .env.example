# required
ABS_URL=
ABS_TOKEN=
HARDCOVER_TOKEN=

# optional
CRON_SCHEDULE= # defaults to 0 3 * * *
CRON_TIMEZONE= # defaults to Europe/Prague

# optional — SMTP email notifications after each scheduled sync
# leave SMTP_HOST empty to disable
SMTP_HOST=     # e.g. smtp.gmail.com
SMTP_PORT=587  # defaults to 587 (STARTTLS); use 25 for plain
SMTP_USER=     # login username (leave empty for unauthenticated relay)
SMTP_PASS=
SMTP_FROM=     # sender address; defaults to abs-hc-sync@<SMTP_HOST>
SMTP_TO=       # recipient address (required to enable notifications)